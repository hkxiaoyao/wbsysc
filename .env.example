# ===== 企微数据中转 MCP Gateway 环境配置（模板）=====
# 复制为 .env 填入真实值，.env 不提交 git

# 运行环境
APP_ENV=dev                       # dev / prod
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
# 已审核且预安装的 wbsysc.connectors 入口名。
# 名称转小写，并将连续的 - _ . 归一为单个 - 后精确匹配。
CONNECTOR_ALLOWLIST=

# MySQL（一期单实例多 schema）
DB_HOST=YOUR_DB_IP                # 主人提供云数据库 IP
DB_PORT=3306
DB_NAME=websysc
DB_USER=websysc
DB_PASSWORD=CHANGE_ME            # 真实密码放 .env，禁止硬编码
DB_POOL_SIZE=5

# MCP 服务
MCP_BASE_URL=https://mcp.example.com   # 生产对外地址（也会用于 Host 白名单推导）
# 允许的 Host 头（逗号分隔）。反代域名写这里，如 wbsysc.hacka.cn
# 留空且 MCP_BASE_URL 也无公网 host 时：关闭 Host 校验（适合反代+Bearer）
MCP_ALLOWED_HOSTS=wbsysc.hacka.cn
# 租户 Token -> corpid 映射（PoC 用环境变量；生产改 DB/KMS）
MCP_TOKENS=
# 独立于 CREDENTIAL_KEY。生产至少 32 个 UTF-8 字节，轮换会使现有 Token 失效。
MCP_TOKEN_HMAC_KEY=

# 企微凭证（每租户独立，PoC 可留空走 mock）
# 真实 corpid/secret 应存 KMS，不写这里。PoC mock 模式可不填。
WECOM_USE_MOCK=true              # true 时用 mock 数据，不调企微
WECOM_CORPID=
WECOM_SECRET=

# Redis（access_token 缓存；PoC 可不用，内存缓存兜底）
REDIS_URL=

# 调度
SYNC_INTERVAL_REPORT_MIN=30      # 汇报同步间隔（分钟）
SYNC_INTERVAL_APPROVAL_MIN=30
SYNC_INTERVAL_SMARTTABLE_MIN=60

# 管理后台
ADMIN_PASSWORD=CHANGE_ME         # 管理后台登录密码（必配，不配则无法登录）
ADMIN_SESSION_TTL_MIN=480        # session 有效期(分钟)，默认8小时
CREDENTIAL_KEY=                  # 凭证加密主密钥，生产至少 32 个 UTF-8 字节
