# 生产环境配置模板
# 复制为 .env.prod，填入真实值，docker compose --env-file .env.prod up -d
# 注意：此文件含敏感信息，绝不提交 git（已在 .dockerignore/.gitignore 排除）

APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=INFO

# ===== 已审核连接器入口 =====
# 使用 wbsysc.connectors 的归一化精确入口名，多个名称用逗号分隔。
CONNECTOR_ALLOWLIST=

# ===== MySQL（生产强密码 + 受限账户）=====
# 同台部署（MySQL在宿主）：DB_HOST 填 host.docker.internal（compose 已配 extra_hosts）
# 跨机部署：填 MySQL 服务器内网 IP
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=websysc
DB_USER=wbsysc_app
DB_PASSWORD=database_password_here
DB_POOL_SIZE=10

# ===== 管理后台 =====
ADMIN_PASSWORD=admin_password_here
ADMIN_SESSION_TTL_MIN=480

# ===== 企微真实数据模式 =====
WECOM_USE_MOCK=false

# ===== 凭证加密主密钥（生产必配强随机，32+字节）=====
# 生成：python -c "import secrets;print(secrets.token_urlsafe(48))"
CREDENTIAL_KEY=replace_with_credential_key

# ===== MCP Token HMAC 密钥（生产必配，必须与 CREDENTIAL_KEY 独立）=====
# 生成：python -c "import secrets;print(secrets.token_urlsafe(48))"
MCP_TOKEN_HMAC_KEY=replace_with_hmac_key

# ===== MCP Token 明文密钥（生产必配，必须与另两把密钥不同）=====
# 生成：python -c "import secrets;print(secrets.token_urlsafe(48))"
MCP_TOKEN_PLAINTEXT_KEY=replace_with_plaintext_key
# 仅在仍有存量 /mcp/service/{service_id} 客户端时临时启用。
MCP_SERVICE_ENABLED=false

# ===== 同步调度（分钟）=====
SYNC_INTERVAL_REPORT_MIN=30
SYNC_INTERVAL_APPROVAL_MIN=30
SYNC_INTERVAL_SMARTTABLE_MIN=60

# ===== Redis（可选，access_token 缓存；PoC 可空走内存）=====
REDIS_URL=

# ===== MCP 对外域名（反代 Host 校验）=====
# 生产建议显式配置，避免 Invalid Host header (421)
MCP_BASE_URL=https://wbsysc.hacka.cn
MCP_ALLOWED_HOSTS=wbsysc.hacka.cn
# 说明：企微 corpid/secret 等租户凭证不在此文件，
# 通过管理后台（/admin/ui/）或 tenant_init 写入 tenant_config（AES 加密）。
# MCP_TOKENS/WECOM_* 旧字段仅 mock/单租户开发期用，生产留空即可。
# 若 MCP_ALLOWED_HOSTS 与 MCP_BASE_URL 都未配公网域名，将关闭 Host 校验（仍靠 Bearer）。
